# ─────────────────────────────────────────
# FICHIER : backend/.env
# Copier ce fichier et renommer en .env, puis adapter les valeurs.
# ─────────────────────────────────────────

# Connexion PostgreSQL — adapter le mot de passe que tu as defini a l'installation
DATABASE_URL=postgresql://postgres:TON_MOT_DE_PASSE@localhost:5432/memolife

# Cle secrete pour signer les tokens JWT (mets n'importe quelle longue chaine aleatoire)
SECRET_KEY=remplace-moi-par-une-longue-chaine-aleatoire-et-secrete

# URL d'Ollama (par defaut, ne pas changer si Ollama tourne en local)
OLLAMA_URL=http://localhost:11434
